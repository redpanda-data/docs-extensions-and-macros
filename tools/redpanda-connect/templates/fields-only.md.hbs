<!-- Format Toggle -->
<div class="format-toggle">
  <button onclick="showFormat('nested')" id="btn-nested" class="active">Nested View</button>
  <button onclick="showFormat('table')" id="btn-table">Table View</button>
</div>

<script>
function showFormat(format) {
  document.querySelectorAll('.format-view').forEach(el => el.style.display = 'none');
  document.querySelectorAll('.format-toggle button').forEach(btn => btn.classList.remove('active'));

  if (format === 'table') {
    document.getElementById('format-table').style.display = 'block';
    document.getElementById('btn-table').classList.add('active');
    history.replaceState(null, null, '#table');
  } else {
    document.getElementById('format-nested').style.display = 'block';
    document.getElementById('btn-nested').classList.add('active');
    history.replaceState(null, null, '#nested');
  }
}

// Check URL fragment on load
window.addEventListener('DOMContentLoaded', function() {
  const hash = window.location.hash.slice(1);
  if (hash === 'table') {
    showFormat('table');
  } else {
    showFormat('nested');
  }
});
</script>

